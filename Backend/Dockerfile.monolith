FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copy everything
COPY . .

# Publish the monolith service
RUN dotnet publish Monolith.API/Monolith.API.csproj -c Release -o /app/publish

# Runtime image
FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 8000
ENV PORT=8000

ENTRYPOINT ["dotnet", "Monolith.API.dll"]
