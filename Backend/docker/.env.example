# --- DATABASE CONFIGURATION ---
# In production, use a strong connection string from your hosting provider.
DATABASE_URL=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-db;Persist Security Info=False;User ID=your-user;Password=your-strong-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# --- SECURITY ---
# JWT_SECRET must be at least 32 characters long and very complex.
JWT_SECRET=your_super_secret_unpredictable_key_32_chars_long

# --- MESSAGE BROKER (RabbitMQ) ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- STORAGE (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=olms-media

# --- EMAIL (SMTP) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SENDER_EMAIL=noreply@lms.com
SMTP_SENDER_NAME=LMS Notifications

# --- STRIPE PAYMENT ---
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# --- ADMIN SEEDING ---
ADMIN_EMAIL=abcxyz@company.com
ADMIN_PASSWORD=Password@admin!123
