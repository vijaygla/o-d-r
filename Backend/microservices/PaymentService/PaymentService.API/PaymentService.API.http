@PaymentService_HostAddress = http://localhost:8013
@AuthToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..cs8gGFHbzxQg9ld509Ky--4fjeJlz5S82BY1uhx19do

### 1. Test Auth
# Role: Authenticated User (Student/Instructor/Admin)
# Purpose: Verifies if the JWT token is valid and extracts user info.
GET {{PaymentService_HostAddress}}/api/payments/test-auth
Authorization: Bearer {{AuthToken}}

### 2. Create Payment Intent
# Role: Authenticated User (Student)
# Purpose: Initiates a Stripe transaction for a specific course.
POST {{PaymentService_HostAddress}}/api/payments/create-intent
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
    "courseId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
    "amount": 49.99,
    "currency": "usd"
}

### 3. Stripe Webhook
# Role: Public (Restricted by Stripe-Signature verification in code)
# Purpose: Stripe calls this automatically when a payment is successful.
POST {{PaymentService_HostAddress}}/api/webhook
Content-Type: application/json
Stripe-Signature: t=123,v1=abc

{
  "id": "evt_test",
  "type": "payment_intent.succeeded",
  "data": {
    "object": {
      "id": "pi_test",
      "amount": 9999,
      "currency": "usd"
    }
  }
}
