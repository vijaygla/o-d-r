@CategoryService_HostAddress = http://localhost:8002
@AuthToken = your-jwt-token-here

### [ANYONE] Get All Categories
# Used by: Students and Instructors to browse course categories
GET {{CategoryService_HostAddress}}/api/Categories

### [ANYONE] Get Category By ID
# Used by: Students to see details of a specific category
GET {{CategoryService_HostAddress}}/api/Categories/5903e12c-b176-437b-b7fd-2068ec72f4c3

### [ADMIN/INSTRUCTOR] Create Category
# Used by: Administrators to define new subject areas
POST {{CategoryService_HostAddress}}/api/Categories
Authorization: Bearer {{AuthToken}}
Content-Type: application/json

{
  "name": "Deep Learning",
  "description": "This is deep learning category"
}

### [ADMIN] Update Category
# Used by: Administrators to refine category details
PUT {{CategoryService_HostAddress}}/api/Categories/f2c5fd32-1f66-498a-ac73-f02767af9184
Authorization: Bearer {{AuthToken}}
Content-Type: application/json

{
  "name": "Updated Cloud Computing",
  "description": "Comprehensive guide to Cloud platforms"
}

### [ADMIN] Delete Category
# Used by: Administrators to remove unused categories
DELETE {{CategoryService_HostAddress}}/api/Categories/f2c5fd32-1f66-498a-ac73-f02767af9184
Authorization: Bearer {{AuthToken}}
