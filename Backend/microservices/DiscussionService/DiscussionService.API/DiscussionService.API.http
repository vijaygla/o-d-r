@DiscussionService_HostAddress = http://localhost:8015
@AuthToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..VYxDuPK2Tdb7BbbwVLAV7LOcLSI_eOcoIDtnR_BhZus
@CourseId = 3fa85f64-5717-4562-b3fc-2c963f66afa6
@ThreadId = 5ea12d89-19de-4a7a-b98b-344aeb14bfc3

### 1. Get Course Threads
# Role: Public / Authenticated (Any User)
# Purpose: Lists all discussion threads for a specific course.
GET {{DiscussionService_HostAddress}}/api/threads/course/{{CourseId}}

### 2. Get Thread Details
# Role: Public / Authenticated (Any User)
# Purpose: Gets a specific thread with all its comments and nested replies.
GET {{DiscussionService_HostAddress}}/api/threads/{{ThreadId}}

### 3. Create a New Thread
# Role: Authenticated (Student / Instructor)
# Purpose: Starts a new discussion topic in a course.
POST {{DiscussionService_HostAddress}}/api/threads
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
    "title": "Need help with EF Core Migrations",
    "content": "I am getting an error while running dotnet ef database update. Any ideas?",
    "courseId": "{{CourseId}}",
    "lessonId": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
}

### 4. Add a Comment
# Role: Authenticated (Student / Instructor)
# Purpose: Replies to a thread or another comment.
POST {{DiscussionService_HostAddress}}/api/threads/comments
Content-Type: application/json
Authorization: Bearer {{AuthToken}}

{
    "threadId": "{{ThreadId}}",
    "content": "this is commnet message",
    "parentCommentId": null
}

### 5. Delete a Thread
# Role: Authenticated (Author / Instructor / Admin)
# Purpose: Removes a thread (Moderation).
DELETE {{DiscussionService_HostAddress}}/api/threads/{{ThreadId}}
Authorization: Bearer {{AuthToken}}
