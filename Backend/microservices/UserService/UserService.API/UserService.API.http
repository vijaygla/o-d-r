@UserService_HostAddress = http://localhost:8011
@AuthToken = your-jwt-token-here

### [AUTHORIZED] Get My Profile
# Access: Any logged-in user (Student, Instructor, Admin)
# Purpose: Allows a user to view their own personal profile data.
GET {{UserService_HostAddress}}/api/user/profile
Authorization: Bearer {{AuthToken}}
Accept: application/json

### [AUTHORIZED] Update My Profile
# Access: Any logged-in user
# Purpose: Allows users to update their bio, skills, and contact info.
PUT {{UserService_HostAddress}}/api/user/profile
Authorization: Bearer {{AuthToken}}
Content-Type: application/json

{
  "fullName": "Student1",
  "bio": "Senior Software Engineer and Lifelong Learner",
  "profilePictureUrl": "https://example.com/profiles/johndoe.jpg",
  "phoneNumber": "+1234567890",
  "location": "New York, USA",
  "skills": ["C#", ".NET Core", "Microservices", "RabbitMQ"],
  "interests": ["Cloud Computing", "AI", "Open Source"],
  "socialLinks": [
    {
      "platform": "LinkedIn",
      "url": "https://linkedin.com/in/johndoe"
    },
    {
      "platform": "GitHub",
      "url": "https://github.com/johndoe"
    }
  ]
}

### [AUTHORIZED] Upload Profile Picture
# Access: Any logged-in user
# Purpose: Uploads a new profile image file.
POST {{UserService_HostAddress}}/api/user/profile/picture
Authorization: Bearer {{AuthToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="profile.jpg"
Content-Type: image/jpeg

< ./profile.jpg
--WebAppBoundary--

### [ADMIN ONLY] Get Profile By ID
# Access: Admin role only
# Purpose: Allows administrators to view any user's profile for moderation.
# Replace with a real User ID from your database
@TargetUserId = 00000000-0000-0000-0000-000000000000
GET {{UserService_HostAddress}}/api/user/{{TargetUserId}}
Authorization: Bearer {{AuthToken}}
Accept: application/json

### [AUTHORIZED] Delete My Account
# Access: Any logged-in user
# Purpose: Permanently deletes the user's account and profile data.
DELETE {{UserService_HostAddress}}/api/user/account
Authorization: Bearer {{AuthToken}}
Accept: application/json
