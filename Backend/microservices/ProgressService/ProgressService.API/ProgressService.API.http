@ProgressService_HostAddress = http://localhost:8006
@Token = your-jwt-token-here
@CourseId = d7826501-3c46-42c3-a3cc-1113960a1532
@LessonId = YOUR_LESSON_GUID_HERE

### [STUDENT] Mark Lesson as Complete
# Access: Any authenticated student.
# Usage: Use this when a student finishes a video or reading material.
POST {{ProgressService_HostAddress}}/api/Progress/mark-complete
Content-Type: application/json
Authorization: Bearer {{Token}}

{
  "courseId": "{{CourseId}}",
  "lessonId": "{{LessonId}}",
  "isCompleted": true
}

### [STUDENT] Get Course Progress
# Access: The student themselves.
# Usage: Returns a summary of all completed lessons and overall percentage for a specific course.
GET {{ProgressService_HostAddress}}/api/Progress/course/{{CourseId}}
Authorization: Bearer {{Token}}
