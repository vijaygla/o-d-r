@IdentityService_HostAddress = http://localhost:8001

### [ANYONE] Register Student User
# Used by: Learners to enroll and view course content. 
# NOTE: User must verify OTP before login will succeed.
POST {{IdentityService_HostAddress}}/api/Auth/register
Content-Type: application/json

{
  "name": "Vijay Kumar",
  "email": "pmdhrs@gmail.com",
  "password": "Vijay@123",
  "role": "Student"
}

### [ANYONE] Verify OTP
# Used by: Users to verify their email address after registration or password reset.
# Use the 6-digit code from your email or the identity.db file.
POST {{IdentityService_HostAddress}}/api/Auth/verify-otp
Content-Type: application/json

{
  "email": "pmdhrs@gmail.com",
  "otp": "328403"
}

### [ANYONE] Resend OTP
# Used by: Users who didn't receive the code or it expired.
POST {{IdentityService_HostAddress}}/api/Auth/resend-otp
Content-Type: application/json

{
  "email": "pmdhrs@gmail.com"
}

### [ANYONE] Login User
# Returns: JWT Token. 
# FAIL: Will return 401 if email is not verified.
POST {{IdentityService_HostAddress}}/api/Auth/login
Content-Type: application/json

{
  "email": "pmdhrs@gmail.com",
  "password": "Password123!"
}

### [ANYONE] Forgot Password
# Sends: A 6-digit OTP to the user's email.
POST {{IdentityService_HostAddress}}/api/Auth/forgot-password
Content-Type: application/json

"pmdhrs@gmail.com"

### [ANYONE] Reset Password
# Used by: Users to set a new password using the OTP received in email.
POST {{IdentityService_HostAddress}}/api/Auth/reset-password
Content-Type: application/json

{
  "email": "pmdhrs@gmail.com",
  "otp": "123456",
  "newPassword": "NewPassword123!"
}

### [ANYONE] Google Login
# Returns: JWT Token for users authenticated via Google.
POST {{IdentityService_HostAddress}}/api/Auth/google-login
Content-Type: application/json

{
  "idToken": "YOUR_GOOGLE_ID_TOKEN_HERE"
}

### [ANYONE] Check Service Status
# Returns: Database and RabbitMQ connectivity status.
GET {{IdentityService_HostAddress}}/api/Auth/status

### [AUTHORIZED] Test Secure Endpoint
# Requires: Valid JWT in Authorization header.
GET {{IdentityService_HostAddress}}/api/Auth/secure
Authorization: Bearer YOUR_TOKEN_HERE

